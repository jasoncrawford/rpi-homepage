---
export interface Props {
  headline?: string;
  headlineHtml?: string;
  bodyHtml: string;
  background?: string;
  variant?: string;
}

const { headline, headlineHtml, bodyHtml, background, variant } = Astro.props;
const sectionClass = ["text", variant].filter(Boolean).join(" ");
const sectionStyle = background ? `background: ${background};` : undefined;
---

<section class={sectionClass} data-view style={sectionStyle}>
  <div class="container">
    <div class="grid">
      {(headline || headlineHtml) && (
        <div class="col-6-md">
          <div class="max t--fadedown">
            {headlineHtml ? (
              <h2 set:html={headlineHtml} />
            ) : (
              <h2>{headline}</h2>
            )}
          </div>
        </div>
      )}
      <div class={headline || headlineHtml ? "col-6-md" : "col-12-sm"}>
        <div class="text t--fadedown t--delay_250">
          <Fragment set:html={bodyHtml} />
        </div>
      </div>
    </div>
  </div>
</section>
