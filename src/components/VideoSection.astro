---
export interface SideLink {
  label: string;
  url: string;
}

export interface Props {
  headline?: string;
  title: string;
  embedUrl: string;
  watchUrl?: string;
  excerpt?: string;
  sideLinks?: SideLink[];
  background?: string;
}

const {
  headline,
  title,
  embedUrl,
  watchUrl,
  excerpt,
  sideLinks = [],
  background = "#fff",
} = Astro.props;

const externalLinkSvg = `<svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M1 11L11 1M11 1H5M11 1V7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
</svg>`;
---

<section class="video" style={`background: ${background};`} data-view>
  <div class="container">
    <div class="grid">
      <div class="col-12-sm">
        {headline && (
          <div class="headline">
            <h2>{headline}</h2><span></span>
          </div>
        )}
        <div class="inside">
          <div class="video">
            <div data-lenis-prevent>
              <iframe
                referrerpolicy="strict-origin-when-cross-origin"
                src={embedUrl}
                allowfullscreen
                title={title}
              ></iframe>
            </div>
          </div>
          <div class="content">
            <h3 class="title">{title}</h3>
            {excerpt && (
              <div class="excerpt">
                <p set:html={excerpt} />
              </div>
            )}
            <div class="bottoms" data-count={watchUrl ? sideLinks.length + 1 : sideLinks.length}>
              {watchUrl && (
                <div>
                  <span>
                    <a href={watchUrl} target="_blank" rel="noopener noreferrer" class="btn">
                      Watch full video
                      <Fragment set:html={externalLinkSvg} />
                    </a>
                  </span>
                </div>
              )}
              {sideLinks.map((link) => (
                <div>
                  <span>
                    <a href={link.url} target="_blank" rel="noopener noreferrer">
                      {link.label}
                    </a>
                  </span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  section.video .bottoms {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 20px;
  }
  section.video .bottoms a.btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--Red);
    color: var(--Cream);
    padding: 9px 14px;
    font-size: 14px;
    font-weight: 500;
    font-family: "F37", Helvetica, Arial, sans-serif;
    text-decoration: none;
    border: 0;
  }
  section.video .bottoms a.btn:hover {
    background: var(--DarkGreen);
  }
  section.video .bottoms a:not(.btn) {
    color: var(--Red);
    border-bottom: 1px solid var(--Red);
    font-size: 14px;
  }
</style>
