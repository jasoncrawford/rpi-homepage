---
export interface Props {
  headline: string;
  headlineHtml?: string;
  description: string;
  scheduleImageUrl?: string;
  scheduleImageAlt?: string;
  scheduleImageWidth?: number;
  scheduleImageHeight?: number;
}

const {
  headline,
  headlineHtml,
  description,
  scheduleImageUrl,
  scheduleImageAlt = "",
  scheduleImageWidth = 1315,
  scheduleImageHeight = 556,
} = Astro.props;
---

<section class="text agenda" data-view>
  <div class="container">
    <div class="grid">
      <div class="col-6-md">
        <div class="max t--fadedown">
          {headlineHtml ? (
            <h2 set:html={headlineHtml} />
          ) : (
            <h2>{headline}</h2>
          )}
        </div>
      </div>
      <div class="col-6-md">
        <div class="text t--fadedown t--delay_250">
          <p set:html={description} />
        </div>
      </div>
    </div>
    {scheduleImageUrl && (
      <div class="grid">
        <div class="col-12-sm">
          <div class="t--fadedown t--delay_250" style="padding-top:40px;">
            <img
              width={scheduleImageWidth}
              height={scheduleImageHeight}
              src={scheduleImageUrl}
              alt={scheduleImageAlt}
              decoding="async"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    )}
  </div>
</section>
