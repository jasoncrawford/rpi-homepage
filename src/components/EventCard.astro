---
export interface Props {
  title: string;
  date: string;
  location?: string;
  description?: string;
  link?: string;
}

const { title, date, location, description, link } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});
---

<div class="event-card">
  <div class="event-card-meta">
    <time class="event-card-date" datetime={date}>{formattedDate}</time>
    {location && <span class="event-card-location">{location}</span>}
  </div>
  <h3 class="event-card-title">{title}</h3>
  {description && <p class="event-card-description">{description}</p>}
  {link && (
    <a href={link} class="event-card-link">
      Learn more →
    </a>
  )}
</div>
