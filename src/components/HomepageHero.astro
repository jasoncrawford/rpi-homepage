---
export interface Props {
  imageSrc: string;
  imageAlt?: string;
  subtitle: string;
  title: string;
  textHtml: string;
}

const { imageSrc, imageAlt = "", subtitle, title, textHtml } = Astro.props;
---

<section class="main" data-view>
  <div class="bg-wrap">
    <div class="bg">
      <div class="parallax">
        <img src={imageSrc} alt={imageAlt} loading="lazy" decoding="async" />
      </div>
    </div>
  </div>
  <div class="container">
    <div class="grid hend-sm">
      <div class="col-6-md">
        <div class="sub t--fade">{subtitle}</div>
        <h1 class="t--fadedown t--delay_250">{title}</h1>
        <div class="text t--fadedown t--delay_500" set:html={textHtml} />
      </div>
    </div>
  </div>
</section>

<style is:global>
  section.main {
    position: relative;
    min-height: calc(var(--vh, 1vh) * 100 - 0px);
    padding-top: 256px;
  }
  @media (max-width: 1023px) {
    section.main {
      min-height: auto;
      padding-top: 75px;
    }
  }
  section.main .bg-wrap {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 100%;
    overflow: hidden;
    z-index: 1;
    pointer-events: none;
  }
  @media (max-width: 1023px) {
    section.main .bg-wrap {
      position: relative;
      padding-bottom: 80%;
      width: 100% !important;
    }
  }
  @media (max-width: 767px) {
    section.main .bg-wrap {
      padding-bottom: 100%;
    }
  }
  section.main .bg {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 50vw;
    overflow: hidden;
  }
  @media (max-width: 1023px) {
    section.main .bg {
      width: 100%;
    }
  }
  section.main .bg .parallax {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
  @media (max-width: 1023px) {
    section.main .bg .parallax {
      height: 110%;
    }
  }
  section.main .bg .parallax img {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  @media (min-width: 1024px) {
    section.main [class*="col-6"] {
      padding-left: 40px;
    }
  }
  section.main .sub {
    margin-bottom: 12px;
  }
  @media (max-width: 1023px) {
    section.main .sub {
      padding-top: 30px;
    }
  }
  section.main h1 {
    margin-bottom: 54px;
  }
  @media (max-width: 767px) {
    section.main h1 {
      margin-bottom: 32.4px;
    }
  }
  section.main .text {
    line-height: 135%;
    padding-right: 25px;
    padding-bottom: 40px;
  }
  section.main .text p + p {
    padding-top: 15px;
  }
  @media (max-width: 1023px) {
    section.main .text {
      padding-right: 0;
    }
  }
</style>

<script>
  /* Parallax scroll effect on the .parallax element */
  (function () {
    const section = document.querySelector('section.main');
    const parallax = section?.querySelector('.parallax');
    if (!parallax) return;

    function onScroll() {
      const scrollY = window.scrollY;
      const offset = scrollY * 0.3;
      (parallax as HTMLElement).style.transform = `translateY(${offset}px)`;
    }

    window.addEventListener('scroll', onScroll, { passive: true });
  })();

  /* Intersection observer to trigger .t--fade / .t--fadedown animations */
  (function () {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.setAttribute('data-animated', '');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 }
    );

    document.querySelectorAll('[data-view]').forEach((el) => observer.observe(el));
  })();
</script>
