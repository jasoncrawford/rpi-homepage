---
import Base from "../../layouts/Base.astro";
import MediaHero from "../../components/MediaHero.astro";
import TextSection from "../../components/TextSection.astro";
import ExpertGrid from "../../components/ExpertGrid.astro";
import AgendaSection from "../../components/AgendaSection.astro";
import VideoSection from "../../components/VideoSection.astro";

const experts = [
  {
    id: "amesh-adalja",
    name: "Amesh Adalja",
    position: "Senior Scholar at Johns Hopkins University; Critical Care, Emergency Medicine, and Infectious Disease physician at the University of Pittsburgh",
    image: "https://rootsofprogress.org/wp-content/uploads/2025/12/Amesh-headshot.png",
    imageWidth: 378,
    imageHeight: 430,
    bio: "<p><strong>Protecting the world from the next infectious threat</strong></p><p>Pittsburgh, PA</p><p>B.S., Industrial Management, Carnegie Mellon; M.D. American University of the Caribbean</p>",
    linkedinUrl: "https://www.linkedin.com/in/amesh/",
    linkedinLabel: "Amesh's LinkedIn",
    profileUrl: "https://rootsofprogress.org/expert/amesh-adalja/",
    profileLabel: "Learn more about Amesh",
  },
  {
    id: "celine-halioua",
    name: "Celine Halioua",
    position: "Founder & CEO, Loyal",
    image: "https://rootsofprogress.org/wp-content/uploads/2025/12/Celine-headshot-scaled-e1764619053913-700x663.jpg",
    imageWidth: 700,
    imageHeight: 663,
    bio: "<p><strong>Drugs to extend dogs' lifespans</strong></p><p>San Francisco, CA</p>",
    profileUrl: "https://rootsofprogress.org/expert/celine-halioua/",
    profileLabel: "Learn more about Celine",
  },
  {
    id: "jared-seehafer",
    name: "Jared Seehafer",
    position: "Senior Advisor, FDA Office of the Commissioner",
    image: "https://rootsofprogress.org/wp-content/uploads/2025/12/Jared-headshot-700x700.png",
    imageWidth: 700,
    imageHeight: 700,
    bio: "<p><strong>Bridging innovation and public health policy</strong></p>",
    linkedinUrl: "https://www.linkedin.com/in/seehafer/",
    linkedinLabel: "Jared's LinkedIn",
    profileUrl: "https://rootsofprogress.org/expert/jared-seehafer/",
    profileLabel: "Learn more about Jared",
  },
  {
    id: "jake-swett",
    name: "Jake Swett",
    position: "Executive Director and Founder, Blueprint Biosecurity",
    image: "https://rootsofprogress.org/wp-content/uploads/2025/12/Jake-headshot-700x467.jpg",
    imageWidth: 700,
    imageHeight: 467,
    bio: "<p><strong>Defending against biological threats</strong></p>",
    linkedinUrl: "https://www.linkedin.com/in/jacob-swett/",
    linkedinLabel: "Jake's LinkedIn",
    profileUrl: "https://rootsofprogress.org/expert/jake-swett/",
    profileLabel: "Learn more about Jake",
  },
];
---

<Base
  title="Progress in Medicine"
  description="A 6-week summer career exploration program for high school students interested in medicine, biotech, health & longevity."
>
  <MediaHero
    src="https://api.rootsofprogress.org/u/2025/11/Teens-with-surgery-robot-v3.png"
    alt=""
    width={1824}
    height={656}
  />

  <TextSection>
    <div slot="left">
      <div class="max t--fadedown">
        <h2>Progress in Medicine 2026</h2>
        <p><b>A Summer Career Exploration Program for High School Students</b></p>
      </div>
    </div>
    <div slot="right">
      <div class="text t--fadedown t--delay_250">
        <p><i>People today live longer, healthier, and less painful lives than ever before. Why? Who made those changes possible? Can we keep this going? And could you play a part?</i></p>
        <p>Discover careers in medicine, biology, and related fields while developing practical tools and strategies for building a meaningful life and career— learning how to find mentors, identify your values, and build a career you love that drives the world forward.</p>
      </div>
    </div>
  </TextSection>

  <TextSection background="#EDEADE">
    <div slot="left">
      <div class="max t--fadedown">
        <h2>About the program</h2>
      </div>
    </div>
    <div slot="right">
      <div class="text t--fadedown t--delay_250">
        <p>Progress in Medicine is a 6-week summer career exploration program for high school students interested in medicine, biotech, health &amp; longevity. 2 hrs/day for 5 weeks online, 4 days in-residency in Stanford with lab and company tours.</p>
      </div>
    </div>
  </TextSection>

  <ExpertGrid
    heading="Expert advisors"
    description="<p>Leaders and experts who can share decades of experience and provide insight on who succeeds in their fields, how, and why. Many have interesting stories to tell and twists and turns in their careers that will broaden your perspective on the many ways you can impact human health.</p><p><b>Click on &quot;Learn more&quot;</b> to read about their unique missions and the paths they took to get there.</p>"
    experts={experts}
  />

  <AgendaSection
    heading="Weekly programming and sessions"
    description="<p>Live Zoom sessions: 1-3 pm PT/4-6 pm ET, Monday - Thursday. No live sessions Fridays: time to read, reflect, write, engage in the discussion board</p>"
    imageSrc="https://api.rootsofprogress.org/u/2025/12/PiM-WeeklyProgramming.svg"
    imageAlt=""
    imageWidth={1315}
    imageHeight={556}
  />

  <AgendaSection
    heading="The Bay Area &amp; Stanford College Experience"
    description="<p>During your time in the Bay Area, you will live in the Stanford dorms (double occupancy)</p><p><i>Tentative schedule; details may change as we confirm company tours and labs</i></p>"
    imageSrc="https://api.rootsofprogress.org/u/2025/12/PiM-BayArea-StandfordCollegeExperience-v2.svg"
    imageAlt=""
    imageWidth={1315}
    imageHeight={548}
  />

  <VideoSection
    headline="Program overview video"
    embedUrl="https://www.youtube-nocookie.com/embed/fnVzcbLWFZE?si=B--WTQHomNeRJOdB"
    videoTitle="Meet your instructor"
    videoLink="https://www.youtube.com/watch?v=fnVzcbLWFZE"
    excerpt="Laura Mazer shares why she's excited about this program. She's developed a curriculum that will leave you in awe of the progress we've made in medicine, and inspired to contribute to the future in biotech, health, and medicine."
    tags={["Read Laura's Substack"]}
    background="#fff"
  />
</Base>
