<Base
  title="Homepage Demo"
  description="Visual demo of the homepage template"
>
  <!-- Section 1: Hero -->
  <HomepageHero
    imageSrc="https://rootsofprogress.org/u/2025/12/rpi_home.jpg"
    imageAlt=""
    subtitle="The Roots of Progress Institute"
    title="A culture of progress for the 21st century"
    textHtml={heroText}
  />

  <!-- Section 2: Newsletter subscribe bar -->
  <NewsletterBanner
    text="<strong>Get essays and announcements by email.</strong>"
    linkText="Subscribe"
    href="/subscribe/"
  />

  <!-- Section 3: Progress Conference 2026 promo -->
  <TextSection dataView={true}>
    <div slot="left">
      <div class="max t--fadedown">
        <h2>Progress Conference 2026</h2>
      </div>
    </div>
    <div slot="right">
      <div class="text t--fadedown t--delay_250">
        <h3>A four-day event to connect people &amp; ideas in the progress movement</h3>
        <p>Presented by the Roots of Progress Institute, together with Abundance Institute, Foresight Institute, Foundation for American Innovation, Human Progress, the Institute for Progress, the Institute for Humane Studies, and Works in Progress.</p>
        <p><i>October 8–11, 2026 in Berkeley, California</i></p>
        <h3>Meet great people &bull; Catalyze new projects &bull; Share ideas &bull; Be energized &amp; inspired</h3>
        <p><b>Location</b>. We're back for a third year at the beautiful Lighthaven campus in Berkeley, CA.</p>
        <p><b>Speakers</b>. 30+ engaging speakers from across the progress movement.</p>
        <p>
          <a href="/conference/" class="btn big">Full 2026 speaker list here</a>
        </p>
        <p>
          <a href="https://rootsofprogress.typeform.com/pc26-apply" target="_blank" rel="noopener" class="btn big">Complete the open application</a>
        </p>
        <p>
          <a href="/conference/">Learn more</a>
        </p>
      </div>
    </div>
  </TextSection>

  <!-- Section 4: Fellowship promo (background #EDEADE) -->
  <TextSection background="#EDEADE" dataView={true}>
    <div slot="full" class="col-12-sm">
      <div class="sep t--fade">
        <span></span>
        <Fragment set:html={rpiLogoMark} />
        <span></span>
      </div>
    </div>
    <div slot="left">
      <div class="max t--fadedown">
        <h2>The Roots of Progress Fellowship is a career accelerator program to empower intellectual entrepreneurs for progress.</h2>
      </div>
      <a href="/fellowship" class="btn big t--fadedown t--delay_250">Learn more</a>
    </div>
    <div slot="right">
      <div class="text t--fadedown t--delay_250">
        <p>Our goal is to empower writers who want to make a career out of explaining <a href="/progress-humanism-agency/">progress, humanism, and agency</a> to a large, general audience. Ultimately, we will help these intellectuals achieve two ambitious goals:</p>
        <p>Be able to sustain themselves as full-time progress intellectuals after this 2–4 year program, by developing a personal brand and sources of revenue to support their work, and</p>
        <p>Write a book or create an equivalent, thematically unified body of work (e.g., a series of essays or blog posts, a scripted podcast series, or a multi-episode documentary) that brings an important topic in progress studies to a general audience.</p>
        <p>
          <a href="/fellowship" class="btn big">Learn more about the fellowship</a>
          &nbsp;
          <a href="/fellows" class="btn big">Meet our fellows</a>
        </p>
      </div>
    </div>
  </TextSection>

  <!-- Section 5: Essays & Talks (video) -->
  <VideoSection
    headline="Essays &amp; Talks"
    embedUrl="https://www.youtube-nocookie.com/embed/0-j1kWVej8k?si=43_k3-qz0w3ceX28"
    videoTitle="Interview: A new philosophy of progress"
    videoLink="https://www.youtube.com/watch?v=0-j1kWVej8k"
    excerpt="In the 1960s, people looked forward to a &ldquo;Jetsons&rdquo; future of flying cars, robots, and nuclear power; today they at best hope to stave off disasters such as pandemics and climate change. What happened to the idea of progress? How do we regain our sense of agency? And how do we move forward, in the 21st century and beyond?"
    tags={["Interviews & Talks", "Philosophy of progress"]}
    background="#fff"
  />

  <!-- Section 6: Featured essays (3-col, with thumbnails, no headline) -->
  <PostsSection items={essayItems} background="#fff" />

  <!-- Section 7: Announcements (3-col, no thumbnails) -->
  <PostsSection headline="Announcements" items={announcementItems} />

  <!-- Section 8: Press (3-col, with thumbnails, external links) -->
  <PostsSection headline="Press" items={pressItems} background="#fff" />

  <!-- Section 9: Support -->
  <SupportSection
    title="Support"
    patreonUrl="https://www.patreon.com/rootsofprogress"
    paypalUrl="https://www.paypal.com/donate?hosted_button_id=DH53T4CSFD8GC"
    contactEmail="jason@rootsofprogress.org"
    moreUrl="/support/"
    moreText="More details here"
  />

  <!-- Section 10: Conference promo bar -->
  <NewsletterBanner
    text="<b>Progress Conference,</b> 16-19 October 2025"
    linkText="Find out more"
    href="/conference/"
  />
</Base>

<style is:global>
  /* Ensure sections go full-width without constraint */
  body > main,
  body main {
    width: 100%;
    max-width: none;
    padding: 0;
    margin: 0;
  }

  /* text section padding from capture/css/text.css */
  section.text {
    padding: 60px 0;
  }
  section.text:first-of-type {
    padding-top: 150px;
  }
  @media (max-width: 1023px) {
    section.text [class*="col-6"] + div {
      padding-top: 20px;
    }
  }
  @media (max-width: 767px) {
    section.text {
      padding: 36px 0;
    }
    section.text:first-child {
      padding-top: 90px;
    }
  }
  section.text .max {
    max-width: 600px;
    position: relative;
  }
  section.text h1 {
    font-size: 46px;
    font-family: "Palast", Helvetica, Arial, sans-serif;
    font-weight: 300;
  }
  @media (max-width: 767px) {
    section.text h1 {
      font-size: 40px;
    }
  }
  section.text h2,
  section.text h3,
  section.text h4 {
    padding-bottom: 14px;
  }
  section.text *+h2,
  section.text *+h3,
  section.text *+h4 {
    padding-top: 27px;
  }
  section.text p {
    line-height: 135%;
  }
  section.text p + p {
    padding-top: 16px;
  }
  section.text .btn {
    margin-top: 7px;
  }
  section#ij2q9ilcka [class*="col-6"] + div .btn.big {
    float: right;
    clear: both;
  }
</style>
