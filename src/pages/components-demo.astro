---
import Base from "../layouts/Base.astro";
import HeroSection from "../components/HeroSection.astro";
import PersonCard from "../components/PersonCard.astro";
import EventCard from "../components/EventCard.astro";

const people = [
  {
    name: "Jane Smith",
    role: "Fellowship Director",
    bio: "Jane leads the Fellowship program, connecting researchers and entrepreneurs working on progress-relevant technologies.",
    website: "https://example.com/jane",
  },
  {
    name: "John Doe",
    role: "Program Manager",
    bio: "John oversees program operations and helps fellows navigate resources and opportunities.",
    website: "https://example.com/john",
  },
  {
    name: "Alice Chen",
    role: "Research Lead",
    bio: "Alice focuses on identifying the most important bottlenecks to technological and scientific progress.",
  },
];

const events = [
  {
    title: "Progress Studies Conference 2026",
    date: "2026-09-15",
    location: "San Francisco, CA",
    description:
      "Annual gathering of researchers, entrepreneurs, and philanthropists working to understand and accelerate human progress.",
    link: "https://example.com/conference-2026",
  },
  {
    title: "Fellowship Application Deadline",
    date: "2026-06-01",
    location: "Remote",
    description:
      "Applications close for the 2026 Roots of Progress Fellowship cohort. Apply to spend a year working on progress-relevant research.",
    link: "https://example.com/apply",
  },
  {
    title: "Progress in Medicine Symposium",
    date: "2026-07-20",
    location: "Boston, MA",
    description:
      "Exploring the history and future of medical innovation, from germ theory to mRNA vaccines and beyond.",
  },
];
---

<Base title="Components Demo" description="Demo page showing HeroSection, PersonCard, and EventCard components">
  <HeroSection
    title="A culture of progress for the 21st century"
    subtitle="While humanity has achieved remarkable progress over the past few centuries, we can and should accelerate it further."
  />

  <section style="margin-top: 3rem;">
    <h2>People</h2>
    <div class="card-grid">
      {people.map((person) => <PersonCard {...person} />)}
    </div>
  </section>

  <section style="margin-top: 3rem;">
    <h2>Events</h2>
    <div class="card-grid">
      {events.map((event) => <EventCard {...event} />)}
    </div>
  </section>
</Base>
